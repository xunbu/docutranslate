# ============================================================
# DocuTranslate 环境变量配置示例
# 复制此文件为 .env 并取消注释需要修改的配置
#
# 这些环境变量设置后端参数的默认值
# 当前端/API调用没有传参时，才使用这些默认值
# ============================================================

# -----------------------------------------------------------
# LLM 基础配置
# -----------------------------------------------------------
# API 密钥
# DOCUTRANSLATE_API_KEY=sk-xxxxxxxx
# API 基础 URL
# DOCUTRANSLATE_BASE_URL=https://api.openai.com/v1
# 模型 ID
# DOCUTRANSLATE_MODEL_ID=gpt-4o
# LLM 供应商标识（openai, azure, anthropic 等）
# DOCUTRANSLATE_PROVIDER=openai
# 目标语言（默认：中文）
# DOCUTRANSLATE_TO_LANG=中文

# -----------------------------------------------------------
# LLM 高级参数
# -----------------------------------------------------------
# 思考模式：default, enable, disable（默认：disable）
# DOCUTRANSLATE_THINKING=disable
# 文本分块大小（默认：4000）
# DOCUTRANSLATE_CHUNK_SIZE=4000
# 并发请求数（默认：30）
# DOCUTRANSLATE_CONCURRENT=30
# 温度参数（默认：0.7）
# DOCUTRANSLATE_TEMPERATURE=0.7
# Top-P 参数（默认：0.9）
# DOCUTRANSLATE_TOP_P=0.9
# 请求超时时间，单位秒（默认：1200）
# DOCUTRANSLATE_TIMEOUT=1200
# 重试次数（默认：2）
# DOCUTRANSLATE_RETRY=2
# 是否使用系统代理（默认：false）
# DOCUTRANSLATE_SYSTEM_PROXY_ENABLE=false
# 强制 JSON 输出（默认：false）
# DOCUTRANSLATE_FORCE_JSON=false
# RPM 限制
# DOCUTRANSLATE_RPM=60
# TPM 限制
# DOCUTRANSLATE_TPM=100000
# 自定义提示词
# DOCUTRANSLATE_CUSTOM_PROMPT=
# 额外请求体 JSON
# DOCUTRANSLATE_EXTRA_BODY=
# 是否启用术语表自动生成（默认：false）
# DOCUTRANSLATE_GLOSSARY_GENERATE_ENABLE=false

# -----------------------------------------------------------
# Markdown 工作流配置
# -----------------------------------------------------------
# PDF 转换引擎：identity, mineru, docling, mineru_deploy（默认：identity）
# DOCUTRANSLATE_CONVERT_ENGINE=identity
# Markdown 转 DOCX 引擎：python, pandoc, auto（默认：auto）
# DOCUTRANSLATE_MD2DOCX_ENGINE=auto

# -----------------------------------------------------------
# MinerU Cloud 配置（convert_engine=mineru 时使用）
# -----------------------------------------------------------
# MinerU API Token
# DOCUTRANSLATE_MINERU_TOKEN=
# MinerU 模型版本：pipeline, vlm（默认：vlm）
# DOCUTRANSLATE_MODEL_VERSION=vlm
# 是否启用公式 OCR（默认：true）
# DOCUTRANSLATE_FORMULA_OCR=true
# 是否启用代码 OCR（默认：true）
# DOCUTRANSLATE_CODE_OCR=true
# MinerU 语言：ch, en, japan 等（默认：ch）
# DOCUTRANSLATE_MINERU_LANGUAGE=ch

# -----------------------------------------------------------
# MinerU Deploy 配置（convert_engine=mineru_deploy 时使用）
# -----------------------------------------------------------
# 本地部署地址（默认：http://127.0.0.1:8000）
# DOCUTRANSLATE_MINERU_DEPLOY_BASE_URL=http://127.0.0.1:8000
# 部署后端（默认：hybrid-auto-engine）
# DOCUTRANSLATE_MINERU_DEPLOY_BACKEND=hybrid-auto-engine
# 解析方法：auto, txt, ocr（默认：auto）
# DOCUTRANSLATE_MINERU_DEPLOY_PARSE_METHOD=auto
# 是否启用表格解析（默认：true）
# DOCUTRANSLATE_MINERU_DEPLOY_TABLE_ENABLE=true
# 是否启用公式解析（默认：true）
# DOCUTRANSLATE_MINERU_DEPLOY_FORMULA_ENABLE=true
# 起始页（默认：0）
# DOCUTRANSLATE_MINERU_DEPLOY_START_PAGE_ID=0
# 结束页（默认：99999）
# DOCUTRANSLATE_MINERU_DEPLOY_END_PAGE_ID=99999
# Server URL（http-client 后端时使用）
# DOCUTRANSLATE_MINERU_DEPLOY_SERVER_URL=

# -----------------------------------------------------------
# Text 工作流配置
# -----------------------------------------------------------
# 插入模式：replace, append, prepend（默认：replace）
# DOCUTRANSLATE_INSERT_MODE=replace
# 分隔符（默认：\n）
# DOCUTRANSLATE_SEPARATOR=\n
# 分段模式：line, paragraph, none（默认：line）
# DOCUTRANSLATE_SEGMENT_MODE=line

# -----------------------------------------------------------
# 系统配置
# -----------------------------------------------------------
# Web 服务端口（默认：8010）
# DOCUTRANSLATE_PORT=8010
# 全局代理开关（默认：false）
# DOCUTRANSLATE_PROXY_ENABLED=false
# 缓存数量（默认：10）
# DOCUTRANSLATE_CACHE_NUM=10
